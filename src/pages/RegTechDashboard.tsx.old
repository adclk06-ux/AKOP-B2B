import { useState, useEffect, useRef } from 'react'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import { Badge } from '@/components/ui/badge'
import { Button } from '@/components/ui/button'
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from '@/components/ui/table'
import {
  CheckCircle, AlertTriangle, Bell,
  RefreshCw, ExternalLink, Loader2, BookOpen,
  Archive, Sparkles, Activity, Clock,
  Globe, Shield, FileText, Zap,
  ChevronLeft, ChevronRight, MoreHorizontal,
  Filter, ChevronDown, FilterX, Lightbulb,
} from 'lucide-react'
import { fetchSpkSyncStatus, fetchSpkArchive, type SpkSyncStatus, analyzeSpkBulletin, analyzeSpkBulletinWithPdf, type SpkBulletinAnalysis } from '@/services/spkSync'
import { getRegTechSuggestions } from '@/services/silentAdvisor'

// SPK-focused dashboard — mock risk records removed

export default function RegTechDashboard() {
  const [spkData, setSpkData] = useState<SpkSyncStatus | null>(null)
  const [spkLoading, setSpkLoading] = useState(false)
  const [analysisByRecordId, setAnalysisByRecordId] = useState<Record<string, SpkBulletinAnalysis & { loading: boolean }>>({})
  const [complianceFilter, setComplianceFilter] = useState(false)
  const [highlightedSource, setHighlightedSource] = useState<string | null>(null)
  const [selectedArchiveYear, setSelectedArchiveYear] = useState<string>('all')
  const [archiveLimit, setArchiveLimit] = useState<number>(1000)
  const [selectedSourceType, setSelectedSourceType] = useState<string>('all')

  const fileInputRefs = useRef<Record<string, HTMLInputElement | null>>({})
  const sourcesRef = useRef<HTMLDivElement>(null)
  const updatesRef = useRef<HTMLDivElement>(null)

  const getAutoKey = (id: string) => `${id}:auto`
  const getUploadKey = (id: string) => `${id}:uploaded`

  const handleAnalyze = async (record: { id: string; number: string; title: string; date: string; isoDate: string; url: string; source?: string; year: number; sourceType: string }) => {
    const key = getAutoKey(record.id)
    setAnalysisByRecordId((prev) => ({ ...prev, [key]: { ...prev[key], loading: true } as any }))
    try {
      const result = await analyzeSpkBulletin(record)
      setAnalysisByRecordId((prev) => ({ ...prev, [key]: { ...result, loading: false } }))
    } catch {
      setAnalysisByRecordId((prev) => ({ ...prev, [key]: { summary: 'Analiz alınamadı.', keyDecisions: [], affectedAreas: [], recommendedAction: 'Lütfen tekrar deneyin.', impactLevel: 'low', complianceChecklist: [], possibleOperationalImpact: 'Bilinmiyor.', sourceBasis: 'fallback', reliability: 'low', errorNote: 'Frontend hatası', disclaimer: '', loading: false } }))
    }
  }

  const handlePdfUpload = async (record: { id: string; number: string; title: string; date: string; isoDate: string; url: string; source?: string; year: number; sourceType: string }, file: File) => {
    const key = getUploadKey(record.id)
    setAnalysisByRecordId((prev) => ({ ...prev, [key]: { ...prev[key], loading: true } as any }))
    try {
      const result = await analyzeSpkBulletinWithPdf(record, file)
      setAnalysisByRecordId((prev) => ({ ...prev, [key]: { ...result, loading: false } }))
    } catch {
      setAnalysisByRecordId((prev) => ({ ...prev, [key]: { summary: 'Analiz alınamadı.', keyDecisions: [], affectedAreas: [], recommendedAction: 'Lütfen tekrar deneyin.', impactLevel: 'low', complianceChecklist: [], possibleOperationalImpact: 'Bilinmiyor.', sourceBasis: 'fallback', reliability: 'low', errorNote: 'Frontend hatası', disclaimer: '', loading: false } }))
    }
  }

  const handleCheckSpk = async () => {
    setSpkLoading(true)
    try {
      const data = await fetchSpkSyncStatus()
      setSpkData(data)
    } finally {
      setSpkLoading(false)
    }
  }

  const handleFetchArchive = async () => {
    setSpkLoading(true)
    try {
      const currentYear = new Date().getFullYear()
      const archive = await fetchSpkArchive({
        startYear: selectedArchiveYear === 'all' ? 2000 : Number(selectedArchiveYear),
        endYear: selectedArchiveYear === 'all' ? currentYear : Number(selectedArchiveYear),
        limit: archiveLimit,
        sourceType: selectedSourceType === 'all' ? undefined : selectedSourceType,
      })
      console.log('[Archive Counts]', archive.counts)
      setSpkData((prev) => prev ? { ...prev, archive: { total: archive.total, records: archive.records, source: archive.source, coverage: archive.coverage, counts: archive.counts } } : { status: 'active', lastCheckedAt: new Date().toISOString(), sources: [], updates: [], archive: { total: archive.total, records: archive.records, source: archive.source, coverage: archive.coverage, counts: archive.counts } })
    } catch (err) {
      console.warn('[Archive Fetch]', err)
    } finally {
      setSpkLoading(false)
    }
  }

  useEffect(() => {
    handleCheckSpk()
  }, [])

  useEffect(() => {
    if (spkData) {
      // eslint-disable-next-line no-console
      console.log('[Archive Records]', spkData.archive?.records?.length ?? 0, 'total:', spkData.archive?.total ?? 0, 'source:', spkData.archive?.source)
    }
  }, [spkData])

  const scrollToRef = (ref: React.RefObject<HTMLDivElement | null>) => {
    ref.current?.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  const handleSourcesClick = () => {
    scrollToRef(sourcesRef)
    if (spkData && spkData.sources.length > 0) {
      setHighlightedSource(spkData.sources[0].name)
      setTimeout(() => setHighlightedSource(null), 2000)
    }
  }

  const handleUpdatesClick = () => {
    setComplianceFilter(false)
    scrollToRef(updatesRef)
  }

  const handleComplianceClick = () => {
    setComplianceFilter(true)
    scrollToRef(updatesRef)
  }

  const [currentPage, setCurrentPage] = useState(1)
  const [pageSize, setPageSize] = useState(20)
  const [autoSync, setAutoSync] = useState(false)

  return (
    <div className="min-h-screen bg-[#F8FAFC]">
      <div className="max-w-[1440px] mx-auto px-6 py-8 space-y-6">
        {/* Header */}
        <div className="flex items-start justify-between">
          <div>
            <h1 className="text-3xl font-bold text-slate-900">RegTech Uyum & Risk</h1>
            <p className="text-slate-500 mt-1">
              SPK, MASAK ve kurum içi uyum metriklerinin gerçek zamanlı takibi.
            </p>
          </div>
          <Button onClick={handleCheckSpk} disabled={spkLoading} className="bg-blue-600 hover:bg-blue-700 text-white">
            {spkLoading ? <Loader2 size={16} className="mr-2 animate-spin" /> : <RefreshCw size={16} className="mr-2" />}
            SPK Kaynaklarını Kontrol Et
          </Button>
        </div>

      {/* SPK Mevzuat Senkronizasyonu */}
      <Card>
        <CardHeader className="flex flex-row items-center justify-between pb-2">
          <div className="flex items-center gap-2">
            <BookOpen size={20} className="text-blue-600" />
            <CardTitle className="text-base">SPK Mevzuat Senkronizasyonu</CardTitle>
          </div>
          <Button onClick={handleCheckSpk} disabled={spkLoading} variant="outline" size="sm">
            {spkLoading ? <Loader2 size={16} className="mr-2 animate-spin" /> : <RefreshCw size={16} className="mr-2" />}
            SPK Kaynaklarını Kontrol Et
          </Button>
        </CardHeader>
        <CardContent className="space-y-6">
          {spkData && (
            <>
              {/* Stats */}
              <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <div className="rounded-lg border p-3 text-center">
                  <p className="text-xs text-muted-foreground mb-1">Durum</p>
                  <Badge className={spkData?.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-700'}>
                    {spkData?.status === 'active' ? 'İzleme Aktif' : 'Pasif'}
                  </Badge>
                </div>
                <div className="rounded-lg border p-3 text-center">
                  <p className="text-xs text-muted-foreground mb-1">Son Kontrol</p>
                  <p className="text-[11px] font-medium text-slate-700">
                    {spkData?.lastCheckedAt ? new Date(spkData.lastCheckedAt).toLocaleString('tr-TR') : '—'}
                  </p>
                </div>
                <button
                  onClick={handleSourcesClick}
                  className="rounded-lg border p-3 text-center cursor-pointer hover:bg-slate-50 hover:border-blue-200 transition-all duration-200 active:scale-[0.99]"
                >
                  <p className="text-xs text-muted-foreground mb-1">İzlenen Kaynak</p>
                  <p className="text-xl font-bold text-blue-600">{spkData?.sources?.length ?? 0}</p>
                </button>
                <button
                  onClick={handleUpdatesClick}
                  className="rounded-lg border p-3 text-center cursor-pointer hover:bg-slate-50 hover:border-blue-200 transition-all duration-200 active:scale-[0.99]"
                >
                  <p className="text-xs text-muted-foreground mb-1">Yeni Güncelleme</p>
                  <p className="text-xl font-bold text-amber-600">{spkData?.updates?.length ?? 0}</p>
                </button>
                <button
                  onClick={handleComplianceClick}
                  className="rounded-lg border p-3 text-center cursor-pointer hover:bg-slate-50 hover:border-blue-200 transition-all duration-200 active:scale-[0.99]"
                >
                  <p className="text-xs text-muted-foreground mb-1">Uyum İncelemesi Gerekli</p>
                  <p className="text-xl font-bold text-rose-600">
                    {spkData?.updates?.filter((u) => u.requiresComplianceReview).length ?? 0}
                  </p>
                </button>
                <div className="rounded-lg border p-3 text-center">
                  <p className="text-xs text-muted-foreground mb-1">Sync Aralığı</p>
                  <p className="text-[11px] font-medium text-slate-700">30 dk</p>
                </div>
              </div>

              {/* Sources */}
              <div ref={sourcesRef}>
                <p className="text-sm font-semibold text-slate-700 mb-3">İzlenen Kaynaklar</p>
                <div className="grid gap-3 md:grid-cols-3">
                  {spkData.sources.map((s) => (
                    <div key={s.name} className={`rounded-lg border p-4 space-y-2 transition-all duration-500 ${highlightedSource === s.name ? 'ring-2 ring-blue-400 bg-blue-50/40' : ''}`}>
                      <div className="flex items-center justify-between">
                        <span className="text-sm font-medium">{s.name}</span>
                        <Badge variant="outline" className="text-[10px]">
                          {s.status === 'ok' ? 'Aktif' : 'Hata'}
                        </Badge>
                      </div>
                      <p className="text-xs text-muted-foreground truncate" title={s.latestTitle}>{s.latestTitle}</p>
                      <p className="text-[10px] text-muted-foreground">{s.latestDate}</p>
                      <a
                        href={s.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        className="inline-flex items-center text-xs text-blue-600 hover:underline"
                      >
                        <ExternalLink size={12} className="mr-1" />
                        SPK sitesini aç
                      </a>
                    </div>
                  ))}
                </div>
              </div>

              {/* Updates Table */}
              {spkData.updates.length > 0 && (
                <div ref={updatesRef}>
                  <div className="flex items-center justify-between mb-3">
                    <p className="text-sm font-semibold text-slate-700">Son Güncellemeler</p>
                    {complianceFilter && (
                      <div className="flex items-center gap-2">
                        <Badge variant="outline" className="text-[10px] text-slate-500 border-slate-200/60">
                          Sadece uyum incelemesi gereken kayıtlar gösteriliyor
                        </Badge>
                        <Button
                          variant="ghost"
                          size="sm"
                          className="h-6 px-2 text-[11px] text-slate-600 hover:text-slate-900"
                          onClick={() => setComplianceFilter(false)}
                        >
                          <FilterX size={12} className="mr-1" />
                          Filtreyi Temizle
                        </Button>
                      </div>
                    )}
                  </div>
                  <div className="overflow-x-auto">
                    <Table>
                      <TableHeader>
                        <TableRow>
                          <TableHead>Kaynak</TableHead>
                          <TableHead>Başlık</TableHead>
                          <TableHead>Etki</TableHead>
                          <TableHead>Özet</TableHead>
                          <TableHead>Tespit Zamanı</TableHead>
                          <TableHead>Uyum İncelemesi</TableHead>
                          <TableHead className="text-right">İşlem</TableHead>
                        </TableRow>
                      </TableHeader>
                      <TableBody>
                        {(complianceFilter
                          ? spkData.updates.filter((u) => u.requiresComplianceReview)
                          : spkData.updates
                        ).map((u) => (
                          <TableRow key={u.id}>
                            <TableCell className="text-xs whitespace-nowrap">{u.source}</TableCell>
                            <TableCell className="text-xs max-w-[200px] truncate" title={u.title}>{u.title}</TableCell>
                            <TableCell>
                              <Badge className={
                                u.impact === 'high' || u.impact === 'critical'
                                  ? 'bg-rose-100 text-rose-700 border-rose-200/60'
                                  : u.impact === 'medium'
                                    ? 'bg-amber-100 text-amber-700 border-amber-200/60'
                                    : 'bg-emerald-100 text-emerald-700 border-emerald-200/60'
                              }>
                                {u.impact === 'high' ? 'Yüksek' : u.impact === 'medium' ? 'Orta' : u.impact === 'critical' ? 'Kritik' : 'Düşük'}
                              </Badge>
                            </TableCell>
                            <TableCell className="text-xs max-w-[250px] truncate" title={u.summary}>{u.summary}</TableCell>
                            <TableCell className="text-xs whitespace-nowrap">{new Date(u.detectedAt).toLocaleString('tr-TR')}</TableCell>
                            <TableCell>
                              {u.requiresComplianceReview ? (
                                <Badge className="bg-rose-100 text-rose-700 border-rose-200/60">Gerekli</Badge>
                              ) : (
                                <Badge variant="outline" className="text-emerald-600 border-emerald-200/60">Gerekmez</Badge>
                              )}
                            </TableCell>
                            <TableCell className="text-right">
                              <a
                                href={u.url || '#'}
                                target="_blank"
                                rel="noopener noreferrer"
                                className="inline-flex items-center gap-1 text-[11px] text-blue-600 hover:underline"
                                onClick={(e) => { if (!u.url || u.url === '#') e.preventDefault() }}
                              >
                                <ExternalLink size={12} />
                                Kaynağı Aç
                              </a>
                            </TableCell>
                          </TableRow>
                        ))}
                      </TableBody>
                    </Table>
                  </div>
                </div>
              )}
            </>
          )}
          {spkLoading && !spkData && (
            <div className="flex items-center justify-center py-12 text-muted-foreground">
              <Loader2 size={20} className="mr-2 animate-spin" />
              SPK kaynakları kontrol ediliyor...
            </div>
          )}
        </CardContent>
      </Card>

      {/* SPK Archive */}
      {(() => {
        const archiveRecords = spkData?.archive?.records ?? []
        const archiveSource = spkData?.archive?.source
        const archiveTotal = spkData?.archive?.total ?? archiveRecords.length
        const coverage = spkData?.archive?.coverage
        const counts = spkData?.archive?.counts
        const filteredRecords = archiveRecords.slice(0, archiveLimit)
        return (
          <Card>
            <CardHeader className="flex flex-row items-center justify-between pb-2">
              <div className="flex items-center gap-2 flex-wrap">
                <Archive size={20} className="text-slate-600" />
                <CardTitle className="text-base">SPK Geçmiş Kayıt Arşivi</CardTitle>
                {archiveSource === 'live' && (
                  <Badge className="bg-emerald-100 text-emerald-700 border-emerald-200/60 text-[10px]">Canlı SPK</Badge>
                )}
                {archiveSource === 'fallback' && (
                  <Badge className="bg-amber-100 text-amber-700 border-amber-200/60 text-[10px]">Demo/Fallback</Badge>
                )}
              </div>
              <div className="flex items-center gap-2 flex-wrap">
                {coverage && coverage.fetchedYears && coverage.fetchedYears.length > 0 && (
                  <Badge variant="outline" className="text-[10px] text-slate-500 border-slate-200/60">
                    {coverage.startYear}–{coverage.endYear}
                  </Badge>
                )}
                {coverage && coverage.skippedYears && coverage.skippedYears.length > 0 && (
                  <Badge variant="outline" className="text-[10px] text-amber-600 border-amber-200/60">
                    Atlanan: {coverage.skippedYears.length} yıl
                  </Badge>
                )}
                {counts && (
                  <>
                    <Badge variant="outline" className="text-[10px] text-slate-500 border-slate-200/60">
                      Bülten: {counts.bulletin}
                    </Badge>
                    <Badge variant="outline" className="text-[10px] text-slate-500 border-slate-200/60">
                      Basın Duyurusu: {counts.pressRelease}
                    </Badge>
                  </>
                )}
                <Badge variant="outline" className="text-[10px]">
                  {archiveTotal} kayıt / {filteredRecords.length} gösteriliyor
                </Badge>
              </div>
            </CardHeader>
            <CardContent className="space-y-4">
              {/* Filter Bar */}
              <div className="flex flex-wrap items-center gap-2 pb-3 border-b border-slate-100">
                <label className="text-[11px] text-slate-500">Yıl:</label>
                <select
                  className="text-[11px] rounded-md border border-slate-200 px-2 py-1 bg-white"
                  value={selectedArchiveYear}
                  onChange={(e) => setSelectedArchiveYear(e.target.value)}
                >
                  <option value="all">Tüm Yıllar</option>
                  {Array.from({ length: 7 }, (_, i) => 2026 - i).map((y) => (
                    <option key={y} value={String(y)}>{y}</option>
                  ))}
                </select>
                <label className="text-[11px] text-slate-500 ml-2">Limit:</label>
                <select
                  className="text-[11px] rounded-md border border-slate-200 px-2 py-1 bg-white"
                  value={archiveLimit}
                  onChange={(e) => setArchiveLimit(Number(e.target.value))}
                >
                  <option value={10}>10</option>
                  <option value={25}>25</option>
                  <option value={50}>50</option>
                  <option value={100}>100</option>
                  <option value={500}>500</option>
                  <option value={1000}>1000</option>
                </select>
                <label className="text-[11px] text-slate-500 ml-2">Tür:</label>
                <select
                  className="text-[11px] rounded-md border border-slate-200 px-2 py-1 bg-white"
                  value={selectedSourceType}
                  onChange={(e) => { setSelectedSourceType(e.target.value); console.log('[Archive Filter] selectedSourceType:', e.target.value) }}
                >
                  <option value="all">Tümü</option>
                  <option value="bulletin">Bültenler</option>
                  <option value="press-release">Basın Duyuruları</option>
                </select>
                <button
                  onClick={handleFetchArchive}
                  disabled={spkLoading}
                  className="inline-flex items-center gap-1 ml-auto rounded-md border border-slate-200 bg-white px-2 py-1 text-[11px] text-slate-700 hover:bg-slate-50 transition-colors disabled:opacity-50"
                >
                  {spkLoading ? <Loader2 size={10} className="animate-spin" /> : <RefreshCw size={10} />}
                  Yenile
                </button>
              </div>

              {archiveSource === 'fallback' && (
                <div className="mb-2 rounded-md bg-amber-50 border border-amber-200/60 p-2.5">
                  <p className="text-[11px] text-amber-700">
                    SPK canlı arşiv erişimi geçici olarak alınamadı, demo/fallback kayıtlar gösteriliyor.
                  </p>
                </div>
              )}

              {filteredRecords.length > 0 ? (
                <div className="overflow-x-auto">
                  <Table>
                    <TableHeader>
                      <TableRow>
                        <TableHead className="text-xs">Kaynak</TableHead>
                        <TableHead className="text-xs">Başlık / Bülten No</TableHead>
                        <TableHead className="text-xs">Tarih</TableHead>
                        <TableHead className="text-xs">Tür</TableHead>
                        <TableHead className="text-xs text-right">İşlem</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {filteredRecords.map((r) => {
                        const autoKey = getAutoKey(r?.id)
                        const uploadKey = getUploadKey(r?.id)
                        const analysis = analysisByRecordId[uploadKey] || analysisByRecordId[autoKey]
                        const isExpanded = !!analysis?.summary
                        return (
                          <>
                            <TableRow key={r?.id}>
                              <TableCell className="text-xs whitespace-nowrap">{r?.source || 'SPK Bültenleri'}</TableCell>
                              <TableCell className="text-xs max-w-[250px] truncate" title={r?.title}>
                                {r?.number} — {r?.title}
                              </TableCell>
                              <TableCell className="text-xs whitespace-nowrap">{r?.isoDate}</TableCell>
                              <TableCell className="text-xs whitespace-nowrap">
                                <Badge variant="outline" className="text-[10px] text-slate-600 border-slate-200/60">
                                  {r?.sourceType === 'bulletin' ? 'Bülten' : 'Duyuru'}
                                </Badge>
                              </TableCell>
                              <TableCell className="text-right">
                                <div className="flex items-center justify-end gap-2">
                                  <button
                                    onClick={() => handleAnalyze(r)}
                                    disabled={analysisByRecordId[autoKey]?.loading}
                                    className="inline-flex items-center gap-1 rounded-md border border-indigo-200 bg-indigo-50 px-2 py-1 text-[11px] text-indigo-700 hover:bg-indigo-100 transition-colors disabled:opacity-50"
                                  >
                                    {analysisByRecordId[autoKey]?.loading ? <Loader2 size={10} className="animate-spin" /> : <Sparkles size={10} />}
                                    AI Özetle
                                  </button>
                                  <button
                                    onClick={() => fileInputRefs.current[r?.id]?.click()}
                                    disabled={analysisByRecordId[uploadKey]?.loading}
                                    className="inline-flex items-center gap-1 rounded-md border border-emerald-200 bg-emerald-50 px-2 py-1 text-[11px] text-emerald-700 hover:bg-emerald-100 transition-colors disabled:opacity-50"
                                  >
                                    {analysisByRecordId[uploadKey]?.loading ? <Loader2 size={10} className="animate-spin" /> : <ExternalLink size={10} />}
                                    PDF Yükle & Analiz Et
                                  </button>
                                  <input
                                    ref={(el) => { fileInputRefs.current[r?.id] = el }}
                                    type="file"
                                    accept=".pdf"
                                    className="hidden"
                                    onChange={(e) => {
                                      const file = e.target.files?.[0]
                                      if (file) handlePdfUpload(r, file)
                                      e.target.value = ''
                                    }}
                                  />
                                  <a
                                    href={r?.url || '#'}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    className="inline-flex items-center gap-1 text-[11px] text-blue-600 hover:underline"
                                    onClick={(e) => { if (!r?.url || r?.url === '#') e.preventDefault() }}
                                  >
                                    <ExternalLink size={12} />
                                    Kaynağı Aç
                                  </a>
                                </div>
                              </TableCell>
                            </TableRow>
                            {isExpanded && (
                              <TableRow key={`${r?.id}-ai`} className="bg-slate-50/50">
                                <TableCell colSpan={5} className="p-0">
                                  <div className="m-2 rounded-md border border-slate-200 bg-slate-50 p-4 space-y-3 max-h-[360px] overflow-y-auto">
                                    <div className="flex items-center gap-2 flex-wrap">
                                      <Sparkles size={14} className="text-indigo-600" />
                                      <p className="text-xs font-semibold text-slate-800">AKOP AI Yorumu</p>
                                      <Badge className={
                                        analysis.impactLevel === 'high' ? 'bg-rose-100 text-rose-700 border-rose-200/60 text-[10px]' :
                                        analysis.impactLevel === 'medium' ? 'bg-amber-100 text-amber-700 border-amber-200/60 text-[10px]' :
                                        'bg-emerald-100 text-emerald-700 border-emerald-200/60 text-[10px]'
                                      }>
                                        {analysis.impactLevel === 'high' ? 'Yüksek Etki' : analysis.impactLevel === 'medium' ? 'Orta Etki' : 'Düşük Etki'}
                                      </Badge>
                                      <Badge variant="outline" className="text-[10px] text-slate-500 border-slate-200/60">
                                        {analysis.sourceBasis === 'uploaded_pdf' ? "Yüklenen PDF'e Göre" : analysis.sourceBasis === 'pdf_content' ? 'PDF İçeriğine Göre' : analysis.sourceBasis === 'metadata_only' ? "Metadata'ya Göre" : 'Fallback'}
                                      </Badge>
                                      {analysis.reliability && (
                                        <Badge className={
                                          analysis.reliability === 'high' ? 'bg-emerald-100 text-emerald-700 border-emerald-200/60 text-[10px]' :
                                          analysis.reliability === 'medium' ? 'bg-amber-100 text-amber-700 border-amber-200/60 text-[10px]' :
                                          'bg-rose-100 text-rose-700 border-rose-200/60 text-[10px]'
                                        }>
                                          {analysis.reliability === 'high' ? 'Yüksek Güvenilirlik' : analysis.reliability === 'medium' ? 'Orta Güvenilirlik' : 'Düşük Güvenilirlik'}
                                        </Badge>
                                      )}
                                    </div>
                                    {analysis.sourceBasis === 'metadata_only' && (
                                      <div className="rounded-md bg-amber-50 border border-amber-200/60 p-2">
                                        <p className="text-[10px] text-amber-700">PDF içeriği okunamadı, analiz sadece bülten bilgisine göre oluşturuldu.</p>
                                      </div>
                                    )}
                                    {analysis.errorNote && (
                                      <div className="rounded-md bg-amber-50 border border-amber-200/60 p-2">
                                        <p className="text-[10px] text-amber-700">Analiz fallback ile üretildi: {analysis.errorNote}</p>
                                      </div>
                                    )}
                                    <p className="text-[11px] text-slate-700 leading-relaxed">{analysis.summary}</p>
                                    {Array.isArray(analysis.keyDecisions) && analysis.keyDecisions.length > 0 && (
                                      <div className="space-y-1">
                                        <p className="text-[10px] font-semibold text-slate-600">Önemli Kararlar</p>
                                        <ul className="list-disc list-inside space-y-0.5">
                                          {analysis.keyDecisions.map((kd, idx) => (
                                            <li key={idx} className="text-[11px] text-slate-700">{kd}</li>
                                          ))}
                                        </ul>
                                      </div>
                                    )}
                                    {Array.isArray(analysis.affectedAreas) && analysis.affectedAreas.length > 0 && (
                                      <div className="flex flex-wrap gap-1">
                                        <p className="text-[10px] font-semibold text-slate-600 mr-1">Etkilenen Alanlar:</p>
                                        {analysis.affectedAreas.map((area) => (
                                          <Badge key={area} variant="outline" className="text-[10px] text-slate-600 border-slate-200/60">{area}</Badge>
                                        ))}
                                      </div>
                                    )}
                                    {Array.isArray(analysis.complianceChecklist) && analysis.complianceChecklist.length > 0 && (
                                      <div className="rounded-md border border-slate-200 bg-white p-2.5 space-y-1">
                                        <p className="text-[10px] font-semibold text-slate-600">Uyum Checklist</p>
                                        <ul className="list-disc list-inside space-y-0.5">
                                          {analysis.complianceChecklist.map((item, idx) => (
                                            <li key={idx} className="text-[11px] text-slate-700">{item}</li>
                                          ))}
                                        </ul>
                                      </div>
                                    )}
                                    <div className="rounded-md border border-slate-200 bg-white p-2.5">
                                      <p className="text-[10px] font-semibold text-slate-600 mb-1">Önerilen Aksiyon</p>
                                      <p className="text-[11px] text-slate-700">{analysis.recommendedAction}</p>
                                    </div>
                                    <div className="rounded-md border border-slate-200 bg-white p-2.5">
                                      <p className="text-[10px] font-semibold text-slate-600 mb-1">Operasyonel Etki</p>
                                      <p className="text-[11px] text-slate-700">{analysis.possibleOperationalImpact}</p>
                                    </div>
                                    <p className="text-[10px] text-slate-400 italic">{analysis.disclaimer}</p>
                                  </div>
                                </TableCell>
                              </TableRow>
                            )}
                          </>
                        )
                      })}
                    </TableBody>
                  </Table>
                </div>
              ) : (
                <div className="flex flex-col items-center justify-center py-10 text-muted-foreground gap-2">
                  <Archive size={32} className="text-slate-300" />
                  <p className="text-sm text-center">
                    Henüz arşiv kaydı bulunamadı.
                  </p>
                  <p className="text-xs text-center text-slate-400">
                    Filtreleri değiştirerek veya "Yenile" butonuyla arşivi güncelleyebilirsiniz.
                  </p>
                </div>
              )}
            </CardContent>
          </Card>
        )
      })()}

      {/* Silent Advisor */}
      <Card className="border-l-4 border-l-indigo-500">
        <CardHeader className="pb-2">
          <div className="flex items-center gap-2">
            <Lightbulb className="text-indigo-600" size={18} />
            <CardTitle className="text-sm">Akıllı Öneri</CardTitle>
            <Badge variant="outline" className="text-[10px] text-slate-500 border-slate-200/60">Silent Advisor</Badge>
          </div>
        </CardHeader>
        <CardContent className="space-y-3">
          {getRegTechSuggestions().slice(0, 2).map((s) => (
            <div key={s.id} className="flex items-start gap-2 rounded-md border p-2.5">
              <div className="mt-0.5 shrink-0">
                {s.severity === 'critical' && <AlertTriangle size={14} className="text-rose-600" />}
                {s.severity === 'warning' && <AlertTriangle size={14} className="text-amber-600" />}
                {s.severity === 'info' && <CheckCircle size={14} className="text-blue-600" />}
              </div>
              <div className="flex-1 min-w-0">
                <div className="flex items-center gap-2 mb-0.5">
                  <p className="text-xs font-semibold text-slate-800">{s.title}</p>
                  <Badge className={
                    s.severity === 'critical' ? 'bg-rose-100 text-rose-700 border-rose-200/60 text-[10px]' :
                    s.severity === 'warning' ? 'bg-amber-100 text-amber-700 border-amber-200/60 text-[10px]' :
                    'bg-blue-100 text-blue-700 border-blue-200/60 text-[10px]'
                  }>
                    {s.severity === 'critical' ? 'Kritik' : s.severity === 'warning' ? 'Uyarı' : 'Bilgi'}
                  </Badge>
                </div>
                <p className="text-[11px] text-muted-foreground">{s.description}</p>
              </div>
            </div>
          ))}
        </CardContent>
      </Card>
      {/* SPK Özet Kartları */}
      <div className="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        <Card className="border-l-4 border-l-emerald-500">
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium">SPK Kaynak Durumu</CardTitle>
            <CheckCircle className="text-emerald-600" size={18} />
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold">{spkData?.sources?.filter((s) => s.status === 'ok').length ?? 0}<span className="text-sm font-normal text-muted-foreground">/{spkData?.sources?.length ?? 0}</span></div>
          </CardContent>
        </Card>
        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium">SPK Güncelleme</CardTitle>
            <Bell className="text-amber-600" size={18} />
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold">{spkData?.updates?.length ?? 0}</div>
          </CardContent>
        </Card>
        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium">Arşiv Kayıt</CardTitle>
            <Archive className="text-blue-600" size={18} />
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold">{spkData?.archive?.total ?? 0}</div>
          </CardContent>
        </Card>
        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium">Uyum İncelemesi Gerekli</CardTitle>
            <AlertTriangle className="text-rose-600" size={18} />
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold">{spkData?.updates?.filter((u) => u.requiresComplianceReview).length ?? 0}</div>
          </CardContent>
        </Card>
        <Card>
          <CardHeader className="flex flex-row items-center justify-between pb-2">
            <CardTitle className="text-sm font-medium">İzlenen Kaynak</CardTitle>
            <BookOpen className="text-slate-600" size={18} />
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold">{spkData?.sources?.length ?? 0}</div>
          </CardContent>
        </Card>
      </div>
    </div>
  )
}
